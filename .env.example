# OpenClaw Integration Environment Variables

# External OpenClaw Instance Configuration
OPENCLAW_GATEWAY_URL=wss://openclaw-vnpa.srv1484467.hstgr.cloud
OPENCLAW_HTTP_URL=https://openclaw-vnpa.srv1484467.hstgr.cloud
OPENCLAW_AUTH_TOKEN=your-gateway-token-here
OPENCLAW_DEFAULT_TIMEOUT=30

# Feature Flags
ENABLE_OPENCLAW_INTEGRATION=true
ENABLE_AI_ANALYSIS=true
ENABLE_REALTIME_OPTIMIZATION=true

# Database Configuration  
DATABASE_URL=your-database-url-here
REDIS_URL=redis://localhost:6379

# Application Configuration
NODE_ENV=development
PORT=3001
GRAPHQL_ENDPOINT=/graphql

# Analytics Service
ANALYTICS_SERVICE_URL=http://localhost:8000